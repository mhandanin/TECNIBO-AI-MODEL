# Copier en .env (non versionne) et adapter si besoin.
POSTGRES_USER=pricing_user
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_DB=pricing_db
# 5433 (pas 5432) : evite le conflit avec une instance PostgreSQL native
# eventuellement deja installee sur la machine (service Windows par exemple).
POSTGRES_PORT=5433

DATABASE_URL=postgresql://pricing_user:change_me_local_dev@localhost:5433/pricing_db

# Cle a fournir dans le header X-API-Key pour appeler POST /predict
API_KEY=change_me_dev_api_key

# URL de base de l'API pricing, utilisee par l'application cliente (app/).
# En local (hors Docker) : http://127.0.0.1:8000
# Via docker-compose : surchargee automatiquement vers http://api:8000
PRICING_API_BASE_URL=http://127.0.0.1:8000

# Port hote pour le service "app" (docker-compose uniquement).
# 8090 (pas 8080) : un serveur natif (Apache/EnterpriseDB) occupe deja le
# 8080 sur cette machine -- meme logique que POSTGRES_PORT plus haut.
APP_PORT=8090
